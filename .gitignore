# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Collections data pulled from data.quipsapp.com at build/preview time
/collections.json
/collections/
# Generated cross-collection feeds, pulled alongside the index
/recently-added.json
/on-this-day.json
/newsletter-picks.json

# Generated by scripts/build-collections.mjs (run in CI; never hand-edit).
# Its collection pages land in /collections/, already ignored above.
/sitemap.xml

# Generated by scripts/build-press-kit.mjs (run in CI; never hand-edit)
/images/quips-press-kit.zip

# Generated by scripts/build-legal.mjs from legal/*.md (run in CI; never
# hand-edit). Edit legal/terms.md / legal/privacy.md instead.
/terms.html
/privacy.html
